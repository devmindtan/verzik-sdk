{
  "name": "@verzik/sdk",
  "version": "0.1.0",
  "description": "Verzik SDK — Hybrid encryption (AES-256-GCM + ECIES) powered by WASM",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "core_wasm/"
  ],
  "scripts": {
    "build": "tsc",
    "build:wasm": "cd ../core_rust && wasm-pack build --target nodejs --out-dir ../ts_wrapper/core_wasm",
    "build:all": "npm run build:wasm && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["encryption", "aes", "ecies", "wasm", "sdk"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
